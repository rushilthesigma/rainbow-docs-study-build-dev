{
  "name": "covalent-ai",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered adaptive learning platform",
  "author": "Rushil Kelapure",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "start": "node server.js",
    "build": "vite build",
    "render-build": "npm install && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "vite build && electron-builder --mac"
  },
  "build": {
    "appId": "com.covalent.ai",
    "productName": "Covalent",
    "mac": {
      "category": "public.app-category.education",
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server.js",
      "prompts.js",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "server.js",
        "to": "server.js"
      },
      {
        "from": "prompts.js",
        "to": "prompts.js"
      }
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.4",
    "vite": "^7.2.4"
  }
}
