{
  "name": "covalent-ai",
  "private": true,
  "version": "1.0.0",
  "description": "RushilAI",
  "author": "Rushil Kelapure",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "node --watch server.js & vite",
    "server": "node --watch server.js",
    "start": "node server.js",
    "build": "vite build",
    "render-build": "npm install && vite build",
    "preview": "vite preview",
    "build:mobile": "node scripts/build-mobile.mjs",
    "mobile:copy": "npm run build:mobile && cap copy",
    "mobile:sync": "npm run build:mobile && cap sync",
    "mobile:android": "npm run mobile:sync && cap open android",
    "mobile:ios": "npm run mobile:sync && cap open ios",
    "mobile:assets": "capacitor-assets generate --ios --android --assetPath assets --iconBackgroundColor '#2563eb' --iconBackgroundColorDark '#2563eb' --splashBackgroundColor '#0a0a14' --splashBackgroundColorDark '#0a0a14'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome/capacitor-google-sign-in": "^0.1.2",
    "@google/generative-ai": "^0.24.1",
    "@tiptap/extension-mathematics": "3.27.1",
    "@tiptap/extension-placeholder": "3.27.1",
    "@tiptap/extension-table": "3.27.1",
    "@tiptap/pm": "3.27.1",
    "@tiptap/react": "3.27.1",
    "@tiptap/starter-kit": "3.27.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.468.0",
    "multer": "^2.1.1",
    "openai": "^6.44.0",
    "pdf-parse": "^1.1.1",
    "pptxgenjs": "^4.0.1",
    "qb-answer-checker": "^1.1.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "stripe": "^22.0.2",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.1.4",
    "vite": "^7.2.4"
  }
}
