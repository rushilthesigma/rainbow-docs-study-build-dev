# Copy to .env.mobile.local and point it at the deployed RushilAI backend.
# HTTPS is required for distributable iOS and Android builds.
VITE_API_BASE_URL=https://your-rushilai-host.example

# The existing Google OAuth web client ID. Native Google Sign-In returns an
# ID token for this audience, which the current /api/auth/google route verifies.
VITE_GOOGLE_CLIENT_ID=000000000000-example.apps.googleusercontent.com

# Public browser origin used as Stripe's success/cancel return destination.
# Usually this is the same origin as VITE_API_BASE_URL.
VITE_PUBLIC_WEB_URL=https://your-rushilai-host.example

